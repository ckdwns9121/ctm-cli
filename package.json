{
  "name": "@devchangjun/ctm",
  "version": "0.1.0",
  "description": "Colo Ticket Manager — Jira-driven branch management CLI",
  "type": "module",
  "bin": {
    "ctm": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "keywords": [
    "jira",
    "git",
    "branch",
    "cli",
    "ticket"
  ],
  "author": "changjun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ckdwns9121/ctm-cli"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "execa": "^9.6.1",
    "ora": "^9.3.0",
    "simple-git": "^3.31.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
